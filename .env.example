# ============================================================
#  Agentic AI Lifecycle Systems — environment template
#  1. Copy this file to ".env"      ->  cp .env.example .env
#  2. Fill in your real values below
#  3. NEVER commit your real ".env" file (it is git-ignored)
# ============================================================

# --- LLM provider (used by the agents and the LLM-as-a-judge, Phase 5) ---
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Base URL of the model / charge API used in the idempotency examples (Phase 3)
LLM_API_BASE=https://api.openai.com/v1

# --- PostgreSQL: checkpoints, intent log, idempotency table (Phases 2-4) ---
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/agents

# --- Redis: high-availability agent state (Phase 4.5) ---
REDIS_URL=redis://localhost:6379/0
